# Runtime
NODE_ENV=production
PORT=3000

# Required
DATABASE_URL=mysql://user:password@host:3306/utme_mock
JWT_SECRET=replace-with-a-long-random-secret
OAUTH_SERVER_URL=https://your-oauth-provider.example.com
OAUTH_CALLBACK_URL=https://api.example.com/api/oauth/callback
FRONTEND_URL=https://app.example.com
VITE_APP_ID=your-app-id
VITE_API_BASE_URL=https://api.example.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-provider.example.com
VITE_OAUTH_CALLBACK_URL=https://api.example.com/api/oauth/callback

# Optional
OWNER_OPEN_ID=
